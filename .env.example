# Variables utilisées par docker-compose.prod.yml
# Copier ce fichier en ".env" à la racine et renseigner de vraies valeurs.
# NE JAMAIS committer le ".env" réel (voir .gitignore).

DB_ROOT_PASSWORD=change_me_root
DB_PASSWORD=change_me_app

# Générer avec: php artisan key:generate --show
APP_KEY=base64:CHANGE_ME

# URL publique de l'API consommée par le frontend au build
VITE_API_URL=http://localhost:8000/api
